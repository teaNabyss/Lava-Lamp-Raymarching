FMaterialLWCData MakeMaterialLWCData(FMaterialVertexParameters Parameters)
{
	FMaterialLWCData Result = (FMaterialLWCData)0;
	Result.PreViewTranslation = ResolvedView.TileOffset.PreViewTranslation;
	Result.PrevPreViewTranslation = ResolvedView.TileOffset.PrevPreViewTranslation;
	Result.WorldViewOrigin = ResolvedView.TileOffset.WorldViewOrigin;
	Result.PrevWorldViewOrigin = ResolvedView.TileOffset.PrevWorldViewOrigin;
	Result.WorldCameraOrigin = ResolvedView.TileOffset.WorldCameraOrigin;
	Result.PrevWorldCameraOrigin = ResolvedView.TileOffset.PrevWorldCameraOrigin;
	Result.AbsoluteWorldPosition = LWCSubtract(Parameters.WorldPosition, Result.PreViewTranslation);
	Result.InstanceToWorld = DFToWS(GetInstanceToWorldDF(Parameters));
	Result.WorldToInstance = DFToWS(GetWorldToInstanceDF(Parameters));
	Result.PreviousInstanceToWorld = DFToWS(GetPrevInstanceToWorldDF(Parameters));
	Result.LocalToWorld = DFToWS(GetLocalToWorldDF(Parameters));
	Result.WorldToLocal = DFToWS(GetWorldToLocalDF(Parameters));
	Result.PreviousLocalToWorld = DFToWS(GetPrevLocalToWorldDF(Parameters));
	Result.PreviousWorldToLocal = DFToWS(GetPrevWorldToLocalDF(Parameters));
	Result.ObjectWorldPosition = GetPrimitiveData(Parameters).ObjectWorldPositionTO;
	Result.ActorWorldPosition = GetPrimitiveData(Parameters).ActorWorldPositionTO;
	Result.ParticleToWorld = DFFastToWS(Parameters.Particle.ParticleToWorld);
	Result.WorldToParticle = DFFastToWS(Parameters.Particle.WorldToParticle);
	Result.ParticleWorldPosition = LWCSubtract(Parameters.Particle.TranslatedWorldPositionAndSize.xyz, Result.PreViewTranslation);
	Result.PrevParticleWorldPosition = LWCSubtract(Parameters.Particle.PrevTranslatedWorldPositionAndSize.xyz, Result.PrevPreViewTranslation);
	return Result;
}
FMaterialLWCData MakeMaterialLWCData(FMaterialPixelParameters Parameters)
{
	FMaterialLWCData Result = (FMaterialLWCData)0;
	Result.PreViewTranslation = ResolvedView.TileOffset.PreViewTranslation;
	Result.PrevPreViewTranslation = ResolvedView.TileOffset.PrevPreViewTranslation;
	Result.WorldViewOrigin = ResolvedView.TileOffset.WorldViewOrigin;
	Result.PrevWorldViewOrigin = ResolvedView.TileOffset.PrevWorldViewOrigin;
	Result.WorldCameraOrigin = ResolvedView.TileOffset.WorldCameraOrigin;
	Result.PrevWorldCameraOrigin = ResolvedView.TileOffset.PrevWorldCameraOrigin;
	Result.AbsoluteWorldPosition = LWCSubtract(Parameters.WorldPosition_CamRelative, Result.PreViewTranslation);
	Result.WorldPosition_NoOffsets = LWCSubtract(Parameters.WorldPosition_NoOffsets_CamRelative, Result.PreViewTranslation);
	Result.InstanceToWorld = DFToWS(GetInstanceToWorldDF(Parameters));
	Result.WorldToInstance = DFFastToWS(GetWorldToInstanceDF(Parameters));
	Result.PreviousInstanceToWorld = DFToWS(GetPrevInstanceToWorldDF(Parameters));
	Result.LocalToWorld = DFToWS(GetLocalToWorldDF(Parameters));
	Result.WorldToLocal = DFFastToWS(GetWorldToLocalDF(Parameters));
	Result.PreviousLocalToWorld = DFToWS(GetPrevLocalToWorldDF(Parameters));
	Result.PreviousWorldToLocal = DFFastToWS(GetPrevWorldToLocalDF(Parameters));
	Result.ObjectWorldPosition = GetPrimitiveData(Parameters).ObjectWorldPositionTO;
	Result.ActorWorldPosition = GetPrimitiveData(Parameters).ActorWorldPositionTO;
	Result.ParticleToWorld = DFFastToWS(Parameters.Particle.ParticleToWorld);
	Result.WorldToParticle = DFFastToWS(Parameters.Particle.WorldToParticle);
	Result.ParticleWorldPosition = LWCSubtract(Parameters.Particle.TranslatedWorldPositionAndSize.xyz, Result.PreViewTranslation);
	Result.PrevParticleWorldPosition = LWCSubtract(Parameters.Particle.PrevTranslatedWorldPositionAndSize.xyz, Result.PrevPreViewTranslation);
	return Result;
}
float3 ReflectionAboutCustomWorldNormal(FMaterialPixelParameters Parameters, float3 WorldNormal, bool bNormalizeInputNormal)
{
	if (bNormalizeInputNormal)
	{
		WorldNormal = normalize(WorldNormal);
	}
	return -Parameters.CameraVector + WorldNormal * dot(WorldNormal, Parameters.CameraVector) * 2.0;
}
_Pragma("dxc diagnostic push")
_Pragma("dxc diagnostic ignored \"-Wall\"") 					_Pragma("dxc diagnostic ignored \"-Wconversion\"") 				_Pragma("dxc diagnostic ignored \"-Wfor-redefinition\"") 		_Pragma("dxc diagnostic ignored \"-Winline-asm\"")				_Pragma("dxc diagnostic ignored \"-Wunsequenced\"")
FLWCScalarDeriv ConstructConstantFWSScalarDeriv(FLWCScalar Value)
{
	FLWCScalarDeriv Ret;
	Ret.Value = Value;
	Ret.Ddx = 0;
	Ret.Ddy = 0;
	return Ret;
}
FLWCVector3Deriv ConstructConstantFWSVector3Deriv(FLWCVector3 Value)
{
	FLWCVector3Deriv Ret;
	Ret.Value = Value;
	Ret.Ddx = 0;
	Ret.Ddy = 0;
	return Ret;
}
FloatDeriv3 Convert_FloatDeriv3_FWSVector3Deriv(FLWCVector3Deriv Src)
{
	FloatDeriv3 Ret;
	Ret.Value = LWCToFloat(Src.Value);
	Ret.Ddx = Src.Ddx;
	Ret.Ddy = Src.Ddy;
	return Ret;
}
FLWCVector3Deriv Convert_FWSVector3Deriv_FloatDeriv(FloatDeriv Src)
{
	FLWCVector3Deriv Ret;
	Ret.Value = LWCPromote(((float3)Src.Value));
	Ret.Ddx = ((float3)Src.Ddx);
	Ret.Ddy = ((float3)Src.Ddy);
	return Ret;
}
FLWCScalarDeriv ExtractFWSVector3Deriv_1(FLWCVector3Deriv InValue)
{
	FLWCScalarDeriv Ret;
	Ret.Value = LWCGetComponent(InValue.Value, 0);
	Ret.Ddx = InValue.Ddx.x;
	Ret.Ddy = InValue.Ddy.x;
	return Ret;
}
FLWCScalarDeriv ExtractFWSVector3Deriv_2(FLWCVector3Deriv InValue)
{
	FLWCScalarDeriv Ret;
	Ret.Value = LWCGetComponent(InValue.Value, 1);
	Ret.Ddx = InValue.Ddx.y;
	Ret.Ddy = InValue.Ddy.y;
	return Ret;
}
FLWCScalarDeriv ExtractFWSVector3Deriv_3(FLWCVector3Deriv InValue)
{
	FLWCScalarDeriv Ret;
	Ret.Value = LWCGetComponent(InValue.Value, 2);
	Ret.Ddx = InValue.Ddx.z;
	Ret.Ddy = InValue.Ddy.z;
	return Ret;
}
FLWCScalarDeriv AddDerivLWC(FLWCScalarDeriv A, FLWCScalarDeriv B)
{
	FLWCScalarDeriv Ret;
	Ret.Value = LWCAdd(A.Value, B.Value);
	Ret.Ddx = A.Ddx + B.Ddx;
	Ret.Ddy = A.Ddy + B.Ddy;
	return Ret;
}
FLWCVector3Deriv SubDerivLWC(FloatDeriv3 A, FLWCVector3Deriv B)
{
	FLWCVector3Deriv Ret;
	Ret.Value = LWCSubtract(A.Value, B.Value);
	Ret.Ddx = A.Ddx - B.Ddx;
	Ret.Ddy = A.Ddy - B.Ddy;
	return Ret;
}
FLWCScalarDeriv MulDerivLWC(FLWCScalarDeriv A, FLWCScalarDeriv B)
{
	FLWCScalarDeriv Ret;
	Ret.Value = LWCMultiply(A.Value, B.Value);
	Ret.Ddx = A.Ddx * LWCToFloat(B.Value) + LWCToFloat(A.Value) * B.Ddx;
	Ret.Ddy = A.Ddy * LWCToFloat(B.Value) + LWCToFloat(A.Value) * B.Ddy;
	return Ret;
}
FLWCVector3Deriv MulDerivLWC(FLWCVector3Deriv A, FLWCVector3Deriv B)
{
	FLWCVector3Deriv Ret;
	Ret.Value = LWCMultiply(A.Value, B.Value);
	Ret.Ddx = A.Ddx * LWCToFloat(B.Value) + LWCToFloat(A.Value) * B.Ddx;
	Ret.Ddy = A.Ddy * LWCToFloat(B.Value) + LWCToFloat(A.Value) * B.Ddy;
	return Ret;
}
FLWCScalarDeriv DotDerivLWC(FLWCVector3Deriv A, FLWCVector3Deriv B)
{
	FLWCScalarDeriv Ret = ConstructConstantFWSScalarDeriv(LWCPromote(0.0f));
	Ret = AddDerivLWC(Ret,MulDerivLWC(ExtractFWSVector3Deriv_1(A),ExtractFWSVector3Deriv_1(B)));
	Ret = AddDerivLWC(Ret,MulDerivLWC(ExtractFWSVector3Deriv_2(A),ExtractFWSVector3Deriv_2(B)));
	Ret = AddDerivLWC(Ret,MulDerivLWC(ExtractFWSVector3Deriv_3(A),ExtractFWSVector3Deriv_3(B)));
	return Ret;
}
FloatDeriv RsqrtDerivLWC(FLWCScalarDeriv A)
{
	FloatDeriv Ret;
	Ret.Value = LWCRsqrt(A.Value);
	float dFdA = -0.5f * LWCRsqrt(A.Value) * LWCRcp(A.Value);	Ret.Ddx = dFdA * A.Ddx;
	Ret.Ddy = dFdA * A.Ddy;
	return Ret;
}
FloatDeriv3 NormalizeDerivLWC(FLWCVector3Deriv A)
{
	FloatDeriv InvLen = RsqrtDerivLWC(DotDerivLWC(A,A));
	FLWCVector3Deriv Ret = MulDerivLWC(Convert_FWSVector3Deriv_FloatDeriv(InvLen), A);
	return Convert_FloatDeriv3_FWSVector3Deriv(Ret);
}
float3 CustomExpression0(FMaterialPixelParameters Parameters,float3 camPos, FLWCVector3 LWCcamPos,float3 rayDir,float3 objPos, FLWCVector3 LWCobjPos,float Time, inout float return)
{
float MAX_DIST = 100000.0;
float MAX_STEPS = 150;
float EPSILON = 0.0001;
float depth = 0;
float3 sphere1Pos = objPos + float3(-30.0, sin(-Time) * cos(-Time) * 10.0, sin(-Time) * 40.0);
float3 sphere2Pos = objPos + float3(sin(Time) * cos(Time) * 25.0, 35.0, sin(Time) * 50.0);
float smoothCoef = 20.0; 
for (int i = 0; i < MAX_STEPS; i++) {
    float3 pos = camPos + (rayDir * depth);
    float sphere1 = length(pos - sphere1Pos) - 40.0;
    float sphere2 = length(pos - sphere2Pos) - 25.0;
    float h = clamp(0.5 + 0.5 * (sphere2 - sphere1) / smoothCoef, 0.0, 1.0);
    float dist = lerp(sphere2, sphere1, h) - smoothCoef * h * (1.0 - h);
    depth += dist;
    if (dist <= EPSILON || depth > MAX_DIST) break;
}
if (depth >= MAX_DIST) {
    OpMask = 0;
    return float4(0.0, 0.0, 0.0, 0.0);
}
OpMask = 1;
float3 surfacePos = camPos + (rayDir * depth);
float3 lightDir = normalize(float3(0.0, 0.0, 0.3));
float s1_xp = length(float3(surfacePos.x + EPSILON, surfacePos.yz) - sphere1Pos) - 40.0;
float s2_xp = length(float3(surfacePos.x + EPSILON, surfacePos.yz) - sphere2Pos) - 25.0;
float h_xp = clamp(0.5 + 0.5 * (s2_xp - s1_xp) / smoothCoef, 0.0, 1.0);
float sdf_xp = lerp(s2_xp, s1_xp, h_xp) - smoothCoef * h_xp * (1.0 - h_xp);
float s1_xn = length(float3(surfacePos.x - EPSILON, surfacePos.yz) - sphere1Pos) - 40.0;
float s2_xn = length(float3(surfacePos.x - EPSILON, surfacePos.yz) - sphere2Pos) - 25.0;
float h_xn = clamp(0.5 + 0.5 * (s2_xn - s1_xn) / smoothCoef, 0.0, 1.0);
float sdf_xn = lerp(s2_xn, s1_xn, h_xn) - smoothCoef * h_xn * (1.0 - h_xn);
float s1_yp = length(float3(surfacePos.x, surfacePos.y + EPSILON, surfacePos.z) - sphere1Pos) - 40.0;
float s2_yp = length(float3(surfacePos.x, surfacePos.y + EPSILON, surfacePos.z) - sphere2Pos) - 25.0;
float h_yp = clamp(0.5 + 0.5 * (s2_yp - s1_yp) / smoothCoef, 0.0, 1.0);
float sdf_yp = lerp(s2_yp, s1_yp, h_yp) - smoothCoef * h_yp * (1.0 - h_yp);
float s1_yn = length(float3(surfacePos.x, surfacePos.y - EPSILON, surfacePos.z) - sphere1Pos) - 40.0;
float s2_yn = length(float3(surfacePos.x, surfacePos.y - EPSILON, surfacePos.z) - sphere2Pos) - 25.0;
float h_yn = clamp(0.5 + 0.5 * (s2_yn - s1_yn) / smoothCoef, 0.0, 1.0);
float sdf_yn = lerp(s2_yn, s1_yn, h_yn) - smoothCoef * h_yn * (1.0 - h_yn);
float s1_zp = length(float3(surfacePos.xy, surfacePos.z + EPSILON) - sphere1Pos) - 40.0;
float s2_zp = length(float3(surfacePos.xy, surfacePos.z + EPSILON) - sphere2Pos) - 25.0;
float h_zp = clamp(0.5 + 0.5 * (s2_zp - s1_zp) / smoothCoef, 0.0, 1.0);
float sdf_zp = lerp(s2_zp, s1_zp, h_zp) - smoothCoef * h_zp * (1.0 - h_zp);
float s1_zn = length(float3(surfacePos.xy, surfacePos.z - EPSILON) - sphere1Pos) - 40.0;
float s2_zn = length(float3(surfacePos.xy, surfacePos.z - EPSILON) - sphere2Pos) - 25.0;
float h_zn = clamp(0.5 + 0.5 * (s2_zn - s1_zn) / smoothCoef, 0.0, 1.0);
float sdf_zn = lerp(s2_zn, s1_zn, h_zn) - smoothCoef * h_zn * (1.0 - h_zn);
float3 normal = normalize(float3(
    sdf_xp - sdf_xn,
    sdf_yp - sdf_yn,
    sdf_zp - sdf_zn
));
float3 diffuseColor = float3(5.0, 1.0, 0.0);
float3 ambientColor = float3(0.1, 0.0, 0.3);
float diffuseLight = clamp(dot(-lightDir, normal), 0.0, 1.0);
diffuseLight = pow(diffuseLight, 2.0);
float3 result = ambientColor + (diffuseLight * diffuseColor);
return float4(result, 1.0);
}
